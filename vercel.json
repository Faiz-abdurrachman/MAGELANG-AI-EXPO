{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/applications", "dest": "/index.js", "methods": ["POST"] },
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
