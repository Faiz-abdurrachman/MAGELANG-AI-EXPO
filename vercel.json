{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/applications", "dest": "/index.js", "methods": ["POST"] },
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/assets/sequence/(.*)", "headers": { "Cache-Control": "public, max-age=31536000, immutable" } },
    { "src": "/assets/(.*)", "headers": { "Cache-Control": "public, max-age=86400" } },
    { "src": "/css/(.*)", "headers": { "Cache-Control": "public, max-age=86400" } },
    { "src": "/js/(.*)", "headers": { "Cache-Control": "public, max-age=86400" } },
    { "src": "/(.*).html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
